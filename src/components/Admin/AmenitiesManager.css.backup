/* AmenitiesManager.css - Estilos mejorados para gestión de comodidades */

.amenities-manager {
  background: #ffffff;
  border-radius: 12px;
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
  padding: 0;
  margin: 0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
}

/* Header */
.amenities-manager-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 2rem;
  border-radius: 12px 12px 0 0;
  margin-bottom: 0;
}

.section-title {
  margin: 0;
  font-size: 1.75rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.section-title i {
  font-size: 1.5rem;
}

/* Estadísticas */
.stats-section {
  padding: 2rem;
  background: #f8f9ff;
  border-bottom: 1px solid #e5e7eb;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1.5rem;
}

.stat-card {
  background: white;
  border-radius: 12px;
  padding: 1.5rem;
  display: flex;
  align-items: center;
  gap: 1rem;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  border: 1px solid #e5e7eb;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.stat-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
}

.stat-icon {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.25rem;
}

.stat-card.total .stat-icon {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
}

.stat-card.department .stat-icon {
  background: linear-gradient(135deg, #f093fb, #f5576c);
  color: white;
}

.stat-card.services .stat-icon {
  background: linear-gradient(135deg, #4facfe, #00f2fe);
  color: white;
}

.stat-card.building .stat-icon {
  background: linear-gradient(135deg, #43e97b, #38f9d7);
  color: white;
}

.stat-content {
  display: flex;
  flex-direction: column;
}

.stat-number {
  font-size: 2rem;
  font-weight: 700;
  color: #1f2937;
  line-height: 1;
}

.stat-label {
  font-size: 0.875rem;
  color: #6b7280;
  font-weight: 500;
}
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 2fr auto;
  gap: 1rem;
  align-items: end;
}

.btn {
  padding: 0.75rem 1rem;
  border: none;
  border-radius: 4px;
  cursor: pointer;
  font-size: 0.9rem;
  font-weight: 600;
  transition: all 0.3s ease;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
}

.btn-primary {
  background: #3498db;
  color: white;
}

.btn-primary:hover {
  background: #2980b9;
}

.btn-primary:disabled {
  background: #bdc3c7;
  cursor: not-allowed;
}

.btn-success {
  background: #27ae60;
  color: white;
}

.btn-success:hover {
  background: #229954;
}

.btn-warning {
  background: #f39c12;
  color: white;
}

.btn-warning:hover {
  background: #e67e22;
}

.btn-danger {
  background: #e74c3c;
  color: white;
}

.btn-danger:hover {
  background: #c0392b;
}

.btn-secondary {
  background: #95a5a6;
  color: white;
}

.btn-secondary:hover {
  background: #7f8c8d;
}

.btn-sm {
  padding: 0.4rem 0.6rem;
  font-size: 0.8rem;
}

.amenities-list {
  margin: 2rem 0;
}

.amenities-list h4 {
  color: #2c3e50;
  margin-bottom: 1rem;
  font-size: 1.2rem;
}

.amenity-items {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.amenity-item {
  border: 1px solid #e9ecef;
  border-radius: 6px;
  overflow: hidden;
}

.amenity-display {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1rem;
  background: white;
}

.amenity-content {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-size: 1rem;
}

.amenity-content i {
  color: #3498db;
  width: 20px;
  text-align: center;
}

.amenity-actions {
  display: flex;
  gap: 0.5rem;
}

.edit-amenity {
  display: grid;
  grid-template-columns: 1fr 2fr auto auto;
  gap: 0.75rem;
  padding: 1rem;
  background: #f8f9fa;
  align-items: center;
}

.no-amenities {
  text-align: center;
  color: #7f8c8d;
  font-style: italic;
  padding: 1rem;
  background: #f8f9fa;
  border-radius: 4px;
}

.amenities-preview {
  background: #f8f9fa;
  padding: 1.5rem;
  border-radius: 6px;
  margin-top: 2rem;
  border: 1px solid #e9ecef;
}

.amenities-preview h4 {
  color: #2c3e50;
  margin-bottom: 1.5rem;
  font-size: 1.2rem;
}

.preview-categories {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 1.5rem;
}

.preview-category {
  background: white;
  padding: 1rem;
  border-radius: 6px;
  border: 1px solid #e9ecef;
}

.preview-category h5 {
  color: #34495e;
  margin-bottom: 0.75rem;
  font-size: 1rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.preview-category h5 i {
  color: #f39c12;
}

.preview-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.preview-list li {
  padding: 0.5rem 0;
  border-bottom: 1px solid #ecf0f1;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.9rem;
}

.preview-list li:last-child {
  border-bottom: none;
}

.preview-list li i {
  color: #3498db;
  width: 16px;
  text-align: center;
}

/* Responsive Design */
@media (max-width: 768px) {
  .form-row {
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  
  .preview-categories {
    grid-template-columns: 1fr;
  }
  
  .amenity-display {
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }
  
  .edit-amenity {
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
}
